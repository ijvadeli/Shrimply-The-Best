{
  "name": "Shrimply The Best",
  "colors": {
    "activityBarBadge.background": "#007acc",
    "sideBarTitle.foreground": "#bbbbbb",

    "editor.background": "#172d44",
    "editor.foreground": "#cce0e6",

    "editor.lineHighlightBackground": "#ffffff08",
    "editor.selectionBackground": "#38cdff33",
    "editor.inactiveSelectionBackground": "#38cdff22",

    "sideBar.background": "#13283c",
    "activityBar.background": "#0f2233",
    "activityBar.foreground": "#cce0e6",
    "activityBar.inactiveForeground": "#6b8aa3",

    "sideBar.foreground": "#cce0e6",
    "sideBarSectionHeader.background": "#0f2233",

	"tab.activeBackground": "#172d44",
	"tab.inactiveBackground": "#13283c",
	"tab.activeForeground": "#ffffff",
	"tab.inactiveForeground": "#7f9bb3",

	"panel.background": "#0f2233",
	"terminal.background": "#0f2233",

	"editorCursor.foreground": "#ffc165",
	"editorCursor.background": "#172d44",

	"editorIndentGuide.background1": "#ffffff14",
	"editorIndentGuide.activeBackground1": "#ffffff2a",

	"titleBar.activeBackground": "#0f2233",
	"titleBar.inactiveBackground": "#0f2233",
	"titleBar.activeForeground": "#cce0e6",
	"titleBar.inactiveForeground": "#7f9bb3",

	"menubar.selectionBackground": "#172d44",
	"menubar.selectionForeground": "#ffffff",
	"menubar.selectionBorder": "#38cdff",

	"commandCenter.background": "#172d44",
	"commandCenter.foreground": "#cce0e6",
	"commandCenter.border": "#38cdff33",

	"editorGroupHeader.tabsBackground": "#172d44",
	"editorGroupHeader.noTabsBackground": "#172d44",

	"tab.border": "#00000000",
	"tab.activeBorderTop": "#38cdff",

    "editorBracketHighlight.foreground1": "#ff8036",
    "editorBracketHighlight.foreground2": "#ffc165",
    "editorBracketHighlight.foreground3": "#b3e09f",
    "editorBracketHighlight.foreground4": "#38cdff",
    "editorBracketHighlight.foreground5": "#82AAFF",
    "editorBracketHighlight.foreground6": "#C792EA",

    "editorBracketPairGuide.activeBackground1": "#ff8036",
    "editorBracketPairGuide.activeBackground2": "#ffc165",
    "editorBracketPairGuide.activeBackground3": "#b3e09f",
    "editorBracketPairGuide.activeBackground4": "#38cdff",
    "editorBracketPairGuide.activeBackground5": "#82AAFF",
    "editorBracketPairGuide.activeBackground6": "#C792EA",

    "editorBracketPairGuide.background1": "#ff803633",
    "editorBracketPairGuide.background2": "#ffc16533",
    "editorBracketPairGuide.background3": "#b3e09f33",
    "editorBracketPairGuide.background4": "#38cdff33",
    "editorBracketPairGuide.background5": "#82AAFF33",
    "editorBracketPairGuide.background6": "#C792EA33"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#627a94"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "string constant.other.placeholder"],
      "settings": {
        "foreground": "#38cdff"
      }
    },
    {
      "name": "Colors",
      "scope": ["constant.other.color"],
      "settings": {
        "foreground": "#cce0e6"
      }
    },
    {
      "name": "Invalid",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#88e2d9"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.control",
        "constant.other.color",
        "meta.tag",
        "keyword.other.template",
        "keyword.other.substitution"
      ],
      "settings": {
        "foreground": "#ffc165"
      }
    },
    {
      "name": "Misc",
      "scope": [
        "punctuation",
        "punctuation.definition.tag",
        "punctuation.separator.inheritance.php",
        "punctuation.definition.tag.html",
        "punctuation.definition.tag.begin.html",
        "punctuation.definition.tag.end.html",
        "punctuation.section.embedded"
      ],
      "settings": {
        "foreground": "#f0f0f0"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "markup.deleted.git_gutter"
      ],
      "settings": {
        "foreground": "#ff5757"
      }
    },
    {
      "name": "Function, Special Method",
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#5bbeff"
      }
    },
    {
      "name": "Block Level Variables",
      "scope": ["meta.block variable.other"],
      "settings": {
        "foreground": "#f0f0f0"
      }
    },
    {
      "name": "Other Variable, String Link",
      "scope": ["support.other.variable", "string.other.link"],
      "settings": {
        "foreground": "#ffc165"
      }
    },
    {
      "name": "Number, Constant, Function Argument, Tag Attribute, Embedded",
      "scope": [
        "constant.numeric",
        "constant.language",
        "support.constant",
        "constant.character",
        "constant.escape",
        "variable.parameter",
        "keyword.other.unit",
        "keyword.other"
      ],
      "settings": {
        "foreground": "#ff8036"
      }
    },
    {
      "name": "String, Symbols, Inherited Class, Markup Heading",
      "scope": [
        "string",
        "constant.other.symbol",
        "constant.other.key",
        "entity.other.inherited-class",
        "markup.heading",
        "markup.inserted.git_gutter",
        "meta.group.braces.curly constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "foreground": "#b3e09f"
      }
    },
    {
      "name": "Class, Support",
      "scope": [
        "entity.name",
        "support.type",
        "support.class",
        "support.other.namespace.use.php",
        "meta.use.php",
        "support.other.namespace.php",
        "markup.changed.git_gutter",
        "support.type.sys-types"
      ],
      "settings": {
        "foreground": "#ff8036"
      }
    },
    {
      "name": "Entity Types",
      "scope": ["support.type"],
      "settings": {
        "foreground": "#b0e9ff"
      }
    },
    {
      "name": "CSS Class and Support",
      "scope": [
        "source.css support.type.property-name",
        "source.sass support.type.property-name",
        "source.scss support.type.property-name",
        "source.less support.type.property-name",
        "source.stylus support.type.property-name",
        "source.postcss support.type.property-name"
      ],
      "settings": {
        "foreground": "#B2CCD6"
      }
    },
    {
      "name": "Sub-methods",
      "scope": [
        "entity.name.module.js",
        "variable.import.parameter.js",
        "variable.other.class.js"
      ],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Language methods",
      "scope": ["variable.language"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FF5370"
      }
    },
    {
      "name": "entity.name.method.js",
      "scope": ["entity.name.method.js"],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#0e3078"
      }
    },
    {
      "name": "meta.method.js",
      "scope": [
        "meta.class-method.js entity.name.function.js",
        "variable.function.constructor"
      ],
      "settings": {
        "foreground": "#82AAFF"
      }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#ffdb81"
      }
    },
    {
      "name": "HTML Attributes",
      "scope": [
        "text.html.basic entity.other.attribute-name.html",
        "text.html.basic entity.other.attribute-name"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#daff7d"
      }
    },
    {
      "name": "CSS Classes",
      "scope": ["entity.other.attribute-name.class"],
      "settings": {
        "foreground": "#daff7d"
      }
    },
    {
      "name": "CSS ID's",
      "scope": ["source.sass keyword.control"],
      "settings": {
        "foreground": "#FFCB6B"
      }
    },
    {
      "name": "Inserted",
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#C3E88D"
      }
    },
    {
      "name": "Deleted",
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#FF5370"
      }
    },
    {
      "name": "Changed",
      "scope": ["markup.changed"],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": ["string.regexp"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "Escape Characters",
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#89DDFF"
      }
    },
    {
      "name": "URL",
      "scope": ["*url*", "*link*", "*uri*"],
      "settings": {
        "fontStyle": "underline"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "tag.decorator.js entity.name.tag.js",
        "tag.decorator.js punctuation.definition.tag.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#0051ff"
      }
    },
    {
      "name": "ES7 Bind Operator",
      "scope": [
        "source.js constant.other.object.key.js string.unquoted.label.js"
      ],
      "settings": {
        "fontStyle": "italic",
        "foreground": "#FF5370"
      }
    },
    {
      "name": "JSON Key - Level 0",
      "scope": [
        "source.json meta.structure.dictionary.json support.type.property-name.json"
